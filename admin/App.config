<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <add name="DefaultConnection" 
         connectionString="Host=xxxx;Database=xxxx;Username=xxxx;Password=xxxx"
         providerName="Npgsql" />
  </connectionStrings>
  <appSettings>
    <add key="Theme" value="Light" />
    <add key="ApplicationName" value="Администрирование" />
  </appSettings>
</configuration>
